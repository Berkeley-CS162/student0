{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/cs162-session-start.sh",
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/cs162-pretool.sh read",
        "matcher": "Read",
        "timeout": 5
      },
      {
        "command": ".cursor/hooks/cs162-pretool.sh write",
        "matcher": "Write",
        "timeout": 5
      },
      {
        "command": ".cursor/hooks/cs162-pretool.sh write",
        "matcher": "StrReplace",
        "timeout": 5
      }
    ]
  }
}
